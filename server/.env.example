PORT=5000
DATABASE_URL="file:./dev.db"
JWT_SECRET="YOUR_JWT_SECRET"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Email Configuration (Nodemailer)
# If left blank, emails will be printed to console and stored in server/temp/emails
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="YOUR_SMTP_USER"
SMTP_PASS="YOUR_SMTP_PASS"
EMAIL_FROM="no-reply@clinicmanager.com"

# Google Calendar OAuth 2.0 Credentials
# If left blank, calendar updates will be simulated
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/google/oauth/callback"
